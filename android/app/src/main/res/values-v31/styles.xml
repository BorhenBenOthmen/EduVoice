<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@color/splash_color</item>
        <!-- Use a transparent 1x1 pixel icon so the system icon is invisible -->
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_icon_blank</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@color/splash_color</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
